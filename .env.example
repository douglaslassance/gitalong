# Local-development env for gitalong's release scripts.
# Copy to `.env` (gitignored) and fill in values. CI runs use GitHub secrets
# of matching names; nothing in this file should ever be committed.
#
# In practice the multi-platform build matrix means a full release happens
# via the CD workflow — building windows + linux artifacts on a single
# host is impractical. This file is for the local tap-submission step
# (./submit_build.sh), which runs after CD has published the GitHub
# Release and only needs to fetch the macOS archives to compute SHAs.

# GitHub (submit_build.sh)
# Personal access token with `repo` scope on the tap repo
# — github.com/settings/tokens. Same env var Peel uses, so a single .env
# file works across both projects.
GITHUB_PERSONAL_ACCESS_TOKEN=
# Tap git URL — the script clones this and pushes a release branch.
# When gitalong is accepted into homebrew-core, change this to
# https://github.com/Homebrew/homebrew-core.git and the script keeps working.
HOMEBREW_TAP_URL=https://github.com/douglaslassance/homebrew-tap.git
